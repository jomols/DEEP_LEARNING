   "source": [
    "import cv2\n",
    "video=cv2.VideoCapture(0)  #read\n",
    "while True:\n",
    "    sucess,img=video.read()\n",
    "\n",
    "    cv2.imshow('Frame',img)\n",
    "    if cv2.waitKey(1)&0XFF==ord('q'):\n",
    "        break\n",
    "video.release() #quit\n",
    "cv2.destroyAllWindows()"
   ]
